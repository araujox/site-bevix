  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && node -e \"try { require('child_process').execSync('npx prisma db push', { stdio: 'inherit' }); } catch(e) { console.log('Database push failed, continuing build...'); }\" && next build",
